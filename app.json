{
  "expo": {
    "name": "SoilStack",
    "slug": "soilstack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "soilstack",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "SoilStack needs camera access to photograph biochar samples and soil for quality verification.",
        "NSLocationWhenInUseUsageDescription": "SoilStack needs your location to record biochar burial GPS coordinates and find nearby verification jobs.",
        "NSPhotoLibraryUsageDescription": "SoilStack needs photo library access to select biochar and soil photos for submissions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D1510",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0D1510"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "SoilStack needs camera access to photograph biochar and soil samples."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SoilStack needs your location to record burial coordinates."
        }
      ],
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
